# API target switch: local | live
VITE_API_TARGET=local
VITE_API_URL_LOCAL=http://127.0.0.1:3000
VITE_API_URL_LIVE=https://api.camrent.ph

# Backward compatibility fallback (used when VITE_API_URL_LOCAL is missing)
VITE_API_URL=http://127.0.0.1:3000
GEMINI_API_KEY=

# Optional endpoint overrides (defaults are internal /api/* routes)
VITE_API_ENDPOINT_STORES=/api/stores
VITE_API_ENDPOINT_STORES_PREFIX=/api/stores/
VITE_API_ENDPOINT_ANNOUNCEMENTS=/api/announcements
VITE_API_ENDPOINT_ACCOUNT_ORDERS=/api/account/orders
VITE_API_ENDPOINT_DASHBOARD_OWNER=/api/dashboard/owner
VITE_API_ENDPOINT_OWNER_APPLICATIONS=/api/owner/applications
VITE_API_ENDPOINT_ITEMS=/api/items
VITE_API_ENDPOINT_ITEMS_PREFIX=/api/items/
VITE_API_ENDPOINT_ITEMS_FEED=/api/items/feed
VITE_API_ENDPOINT_OWNER_FRAUD_LIST=/api/owner/fraud-list
VITE_API_ENDPOINT_OWNER_RENTAL_FORM=/api/owner/rental-form
VITE_API_ENDPOINT_OWNER_STORE_PROFILE=/api/owner/store-profile
VITE_API_ENDPOINT_OWNER_CUSTOMERS_REPORT_FRAUD=/api/owner/customers/report-fraud
VITE_API_ENDPOINT_OWNER_SUPPORT_TICKETS=/api/owner/support-tickets
VITE_API_ENDPOINT_OWNER_SUPPORT_TICKETS_PREFIX=/api/owner/support-tickets/
VITE_API_ENDPOINT_UPLOAD=/api/upload
VITE_API_ENDPOINT_UPLOAD_PUBLIC=/api/upload/public
VITE_API_ENDPOINT_UPLOAD_PUBLIC_ACCESS=/api/upload/public/access
VITE_API_ENDPOINT_UPLOAD_PUBLIC_STRICT_CLOUDINARY=/api/upload/public/strict-cloudinary
VITE_API_ENDPOINT_MANUAL_BLOCKS=/api/manual-blocks
VITE_API_ENDPOINT_ORDERS=/api/orders
VITE_API_ENDPOINT_ORDERS_PREFIX=/api/orders/
VITE_API_ENDPOINT_AUTH_LOGIN=/api/auth/login
VITE_API_ENDPOINT_AUTH_REGISTER=/api/auth/register
VITE_API_ENDPOINT_DASHBOARD_ADMIN=/api/dashboard/admin
VITE_API_ENDPOINT_ADMIN_STORES_PREFIX=/api/admin/stores/
VITE_API_ENDPOINT_ADMIN_CUSTOMERS_PREFIX=/api/admin/customers/
VITE_API_ENDPOINT_ADMIN_FRAUD_LIST=/api/admin/fraud-list
VITE_API_ENDPOINT_ADMIN_FRAUD_LIST_PREFIX=/api/admin/fraud-list/
VITE_API_ENDPOINT_ADMIN_FRAUD_ANALYTICS=/api/admin/fraud-analytics
VITE_API_ENDPOINT_ADMIN_SUPPORT_TICKETS=/api/admin/support-tickets
VITE_API_ENDPOINT_ADMIN_SUPPORT_TICKETS_PREFIX=/api/admin/support-tickets/
VITE_API_ENDPOINT_ADMIN_ANNOUNCEMENTS=/api/admin/announcements
VITE_API_ENDPOINT_ADMIN_ANNOUNCEMENTS_PREFIX=/api/admin/announcements/
